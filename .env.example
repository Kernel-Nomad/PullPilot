# docker-compose / deployment
DOCKER_ROOT_PATH=/home/user/my_projects
PULLPILOT_PORT=8000
TZ=Europe/Madrid

# backend runtime
DATA_DIR=/app/data
PROJECTS_ROOT=/home/user/my_projects
HEALTHCHECK_TIMEOUT=60
COMMAND_TIMEOUT=300

# optional auth
AUTH_USER=admin
AUTH_PASS=change-me

# session configuration
SESSION_SECRET=replace-this-with-a-fixed-secret
SESSION_HTTPS_ONLY=false
