# =============================================================================
# Mínimo recomendado (producción con Docker Compose)
# =============================================================================
# Misma ruta en host y contenedor (volumen bind en docker-compose.yml).
DOCKER_ROOT_PATH=/home/user/my_projects
TZ=Europe/Madrid

AUTH_USER=admin
AUTH_PASS=change-me
# Fijo entre reinicios; si se omite, se genera uno nuevo en cada arranque.
SESSION_SECRET=replace-this-with-a-fixed-secret

# Puerto publicado (opcional; el compose usa ${PULLPILOT_PORT:-8000})
# PULLPILOT_PORT=8000

# =============================================================================
# Opcional / avanzado
# =============================================================================
# DATA_DIR: por defecto /app/data; el volumen pullpilot_data del compose oficial
# ya persiste ahí. Solo cámbialo si sabes qué haces.
# DATA_DIR=/app/data

# Solo si la ruta dentro del contenedor debe diferir de DOCKER_ROOT_PATH
# PROJECTS_ROOT=/home/user/my_projects

# HEALTHCHECK_TIMEOUT=60
# COMMAND_TIMEOUT=300

SESSION_HTTPS_ONLY=false
# CORS_ORIGINS=https://pullpilot.example.com

# Rate limit de login (memoria, por IP); un solo worker uvicorn recomendado
# LOGIN_RATE_LIMIT_ENABLED=true
# LOGIN_RATE_LIMIT_MAX=15
# LOGIN_RATE_LIMIT_WINDOW_SEC=300

# Solo tras reverse proxy de confianza (cabecera X-Forwarded-For)
# TRUST_X_FORWARDED_FOR=false
