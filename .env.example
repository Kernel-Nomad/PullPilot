# Copy this file to .env in the same directory as docker-compose.yml (see README).
# =============================================================================
# Recommended minimum (production with Docker Compose)
# =============================================================================
# Same path on host and container (bind mount in docker-compose.yml).
DOCKER_ROOT_PATH=/home/user/my_projects
TZ=Europe/Madrid

AUTH_USER=admin
AUTH_PASS=change-me
# Stable across restarts; if omitted, a new value is generated on each startup.
SESSION_SECRET=replace-this-with-a-fixed-secret

# Published port (optional; compose uses ${PULLPILOT_PORT:-8000})
# PULLPILOT_PORT=8000

# =============================================================================
# Optional / advanced
# =============================================================================
# DATA_DIR: defaults to /app/data; the official compose pullpilot_data volume
# already persists there. Change only if you know what you are doing.
# DATA_DIR=/app/data

# Only if the path inside the container must differ from DOCKER_ROOT_PATH
# PROJECTS_ROOT=/home/user/my_projects

# HEALTHCHECK_TIMEOUT=60
# COMMAND_TIMEOUT=300

SESSION_HTTPS_ONLY=false
# CORS_ORIGINS=https://pullpilot.example.com

# Login rate limit (in-memory, per IP); single uvicorn worker recommended
# LOGIN_RATE_LIMIT_ENABLED=true
# LOGIN_RATE_LIMIT_MAX=15
# LOGIN_RATE_LIMIT_WINDOW_SEC=300

# Only behind a trusted reverse proxy (X-Forwarded-For header)
# TRUST_X_FORWARDED_FOR=false
