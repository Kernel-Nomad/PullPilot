# Optional: save as `.env` next to docker-compose.yml. The official compose works
# without any .env if you use the default stacks path /srv/docker-stacks.
#
# After editing .env: docker compose up -d  OR  docker compose restart
#
# -----------------------------------------------------------------------------
# 1) Stacks path — only if you do NOT use /srv/docker-stacks
# -----------------------------------------------------------------------------
# Same absolute path on host and inside the container (bind mount in compose).
# DOCKER_ROOT_PATH=/home/user/my_projects

# -----------------------------------------------------------------------------
# 2) Port and timezone (optional)
# -----------------------------------------------------------------------------
# PULLPILOT_PORT=8000
# TZ=Europe/Madrid

# -----------------------------------------------------------------------------
# 3) Auth — default outside Docker: ALLOW_NO_AUTH=false ⇒ AUTH_* required to start
# -----------------------------------------------------------------------------
# Official docker-compose sets ALLOW_NO_AUTH=true for quick LAN-only start.
# ALLOW_NO_AUTH=false
# AUTH_USER=admin
# AUTH_PASS=your-secure-password
# SESSION_SECRET=   # fixed so sessions survive restarts: openssl rand -hex 32
# If UVICORN_WORKERS > 1, SESSION_SECRET is mandatory.

# -----------------------------------------------------------------------------
# 4) Other / advanced (see README "Environment variables (reference)")
# -----------------------------------------------------------------------------
# DATA_DIR defaults to /app/data; official compose uses pullpilot_data volume.
# DATA_DIR=/app/data

# Official image sets this so the SPA is served from the Vite dist (see Dockerfile).
# STATIC_DIR=/app/server/static

# Different path inside the container than on the host (rare)
# PROJECTS_ROOT=/path/inside/container

# SESSION_HTTPS_ONLY=false
# SESSION_SAME_SITE=lax   # lax | strict | none (none needs HTTPS / Secure cookie)
# CORS_ORIGINS=https://pullpilot.example.com

# HEALTHCHECK_TIMEOUT=60
# COMMAND_TIMEOUT=300

# Language for scheduled update logs (es | en). UI-triggered updates use browser language.
# LOG_LOCALE=es

# LOGIN_RATE_LIMIT_ENABLED=true
# LOGIN_RATE_LIMIT_MAX=15
# LOGIN_RATE_LIMIT_WINDOW_SEC=300

# TRUST_X_FORWARDED_FOR=false
